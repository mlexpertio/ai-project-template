# Backend
AI_PROVIDER=ollama
MODEL_NAME=qwen3:4b
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
MAX_CONTEXT_CHARS=25000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Docker notes:
# - docker compose overrides OLLAMA_BASE_URL to http://host.docker.internal:11434
#   so the backend container can reach Ollama running on your host machine.
